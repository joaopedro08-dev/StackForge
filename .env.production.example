# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
APP_HOST_PORT=3001
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://api.seudominio.com
CORS_ALLOWED_ORIGINS=https://app.seudominio.com

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_PROVIDER=postgresql
POSTGRES_HOST_PORT=5432
POSTGRES_DB=authentication_api
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=change_me
# Prefer explicit URL in production. If empty, app derives URL from provider + DB_PORT_*
DATABASE_URL=postgresql://auth_user:change_me@postgres:5432/authentication_api?schema=public

DB_PORT_MYSQL=3306
DB_PORT_POSTGRESQL=5432
DB_PORT_SQLITE=0
DB_PORT_SQLSERVER=1433

# -----------------------------------------------------------------------------
# Security / Rate Limiting
# -----------------------------------------------------------------------------
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX_REQUESTS=100
LOGIN_ATTEMPT_WINDOW_MINUTES=15
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_BLOCK_DURATION_MINUTES=15
LOGIN_BLOCK_BACKOFF_MULTIPLIER=2
LOGIN_MAX_BLOCK_DURATION_MINUTES=240
CSRF_TOKEN_TTL_MINUTES=120

# -----------------------------------------------------------------------------
# Authentication / JWT
# -----------------------------------------------------------------------------
JWT_ACCESS_ACTIVE_KID=v1
JWT_ACCESS_SECRETS=v1:change-with-a-very-long-random-secret
JWT_ACCESS_SECRET=change-with-a-very-long-random-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7
