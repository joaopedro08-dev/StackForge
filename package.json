{
  "name": "stackforge",
  "version": "1.0.0",
  "private": true,
  "description": "StackForge SaaS authentication API with register, login, me, refresh-token and logout.",
  "main": "index.js",
  "scripts": {
    "dev:new-project": "node scripts/new-auth-project.mjs",
    "dev": "nodemon index.js",
    "start": "node index.js",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:scaffold:readme": "vitest run tests/scripts/new-auth-project.readme-sections.test.js",
    "test:scaffold:db": "node scripts/scaffold-db-smoke.mjs",
    "test:scaffold:arch-api": "node scripts/scaffold-architecture-api-smoke.mjs",
    "test:scaffold:full-runtime": "node scripts/scaffold-full-runtime-smoke.mjs",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push --skip-generate",
    "prisma:bootstrap": "node scripts/prisma-bootstrap.mjs",
    "lint": "eslint . --max-warnings=0",
    "audit": "pnpm audit --audit-level=high",
    "prod:up": "docker compose --env-file .env.production -f docker-compose.production.yml up -d",
    "prod:up:build": "docker compose --env-file .env.production -f docker-compose.production.yml up -d --build",
    "prod:up:dbport": "node scripts/production-up-db-port.mjs",
    "prod:down": "docker compose --env-file .env.production -f docker-compose.production.yml down",
    "prod:reset": "docker compose --env-file .env.production -f docker-compose.production.yml down -v --remove-orphans",
    "prod:ps": "docker compose --env-file .env.production -f docker-compose.production.yml ps",
    "prod:smoke": "node scripts/production-smoke.mjs",
    "prod:smoke:auth": "node scripts/production-auth-smoke.mjs",
    "prod:verify": "pnpm prod:smoke && pnpm prod:smoke:auth",
    "prod:deploy:local": "pnpm prod:up && pnpm prod:verify",
    "prod:recovery:test": "pnpm prod:reset && pnpm prod:up && pnpm prod:verify",
    "perf:docker:du": "docker system df",
    "perf:docker:clean": "docker image prune -f && docker builder prune -f",
    "perf:docker:clean:volumes": "docker volume prune -f",
    "perf:docker:maintain": "pnpm perf:docker:du && pnpm perf:docker:clean && pnpm perf:docker:clean:volumes && pnpm perf:docker:du"
  },
  "type": "module",
  "keywords": [
    "authentication",
    "api",
    "jwt",
    "nodejs",
    "express",
    "auth",
    "backend",
    "boilerplate",
    "saas"
  ],
  "author": "João Pedro Dala Dea Mello",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lowdb": "^7.0.1",
    "prisma": "6.19.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.8.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "supertest": "^7.2.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}