# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Frontend origin allowed to send cookies (credentials)
CORS_ORIGIN=http://localhost:3000
# Comma-separated allowlist used by CORS middleware
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Supported providers: json, mysql, postgresql, sqlite, sqlserver
DATABASE_PROVIDER=json
# Optional. If empty, the app builds a default URL using DATABASE_PROVIDER + DB_PORT_*
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/authentication_api?schema=public

# Default relational database ports
DB_PORT_MYSQL=3306
DB_PORT_POSTGRESQL=5432
# SQLite does not use a network port
DB_PORT_SQLITE=0
DB_PORT_SQLSERVER=1433

# -----------------------------------------------------------------------------
# Security / Rate Limiting
# -----------------------------------------------------------------------------
# Request limit applied to /auth routes
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX_REQUESTS=100

# Brute-force protection for /auth/login by IP + email
LOGIN_ATTEMPT_WINDOW_MINUTES=15
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_BLOCK_DURATION_MINUTES=15
LOGIN_BLOCK_BACKOFF_MULTIPLIER=2
LOGIN_MAX_BLOCK_DURATION_MINUTES=240

# CSRF token cookie lifetime (minutes)
CSRF_TOKEN_TTL_MINUTES=120

# -----------------------------------------------------------------------------
# Authentication / JWT
# -----------------------------------------------------------------------------
# JWT key rotation (kid)
JWT_ACCESS_ACTIVE_KID=v1
# Format: kid:secret,kid2:secret2
JWT_ACCESS_SECRETS=v1:change-this-access-secret-please
JWT_ACCESS_SECRET=change-this-access-secret-please
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7
